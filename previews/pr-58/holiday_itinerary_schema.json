{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "version": "3.0.0",
  "title": "HolidayItinerary",
  "description": "Structured holiday itinerary with transport, accommodation and events (gigs, walks, festivals, etc.)",
  "type": "object",
  "required": [
    "trip",
    "segments"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Version of this schema the document was written for (copies the schema's top-level \"version\"). The viewer writes it on download and checks its MAJOR part on load. Optional for now; will become required in a future MAJOR version."
    },
    "trip": {
      "type": "object",
      "required": [
        "name",
        "travellers",
        "start",
        "end",
        "currency_primary"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "travellers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "start": {
          "type": "string",
          "format": "date"
        },
        "end": {
          "type": "string",
          "format": "date"
        },
        "currency_primary": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "passes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/Pass"
          },
          "description": "Trip-level travel passes (e.g. an Interrail pass). Transport segments covered by a pass reference it via pass_id instead of repeating the pass in each leg's ref."
        }
      },
      "additionalProperties": false
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "$ref": "#/definitions/TransportSegment"
          },
          {
            "$ref": "#/definitions/AccommodationSegment"
          },
          {
            "$ref": "#/definitions/EventSegment"
          }
        ]
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "Cost": {
      "type": "object",
      "required": [
        "status"
      ],
      "if": {
        "properties": {
          "status": {
            "enum": [
              "paid",
              "pending"
            ]
          }
        }
      },
      "then": {
        "anyOf": [
          {
            "required": [
              "amount"
            ]
          },
          {
            "required": [
              "payments"
            ]
          }
        ]
      },
      "properties": {
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$",
          "description": "ISO-4217 code; when omitted the trip's currency_primary applies"
        },
        "status": {
          "type": "string",
          "enum": [
            "paid",
            "pending",
            "free",
            "not_booked",
            "included"
          ]
        },
        "paid_by": {
          "type": "string",
          "description": "Traveller who paid (or will pay) this cost — should match a value in trip.travellers. Use payments[].paid_by instead when instalments are split between travellers."
        },
        "due": {
          "type": "string",
          "format": "date",
          "description": "ISO date payment is due"
        },
        "note": {
          "type": "string"
        },
        "included_in": {
          "type": "string",
          "description": "ID of segment this cost is bundled with"
        },
        "amount": {
          "type": "number",
          "minimum": 0,
          "description": "The single total amount for this cost. When payments[] is present it must equal their sum (checked by lint, not the schema)."
        },
        "payments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "amount",
              "status"
            ],
            "properties": {
              "amount": {
                "type": "number",
                "minimum": 0
              },
              "status": {
                "type": "string",
                "enum": [
                  "paid",
                  "pending"
                ]
              },
              "paid_by": {
                "type": "string",
                "description": "Traveller who made (or will make) this instalment — overrides Cost.paid_by for this payment"
              },
              "date": {
                "type": "string",
                "format": "date",
                "description": "Date paid (if paid)"
              },
              "due": {
                "type": "string",
                "format": "date",
                "description": "Date due (if pending)"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "Pass": {
      "type": "object",
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Short unique id transport segments reference via pass_id, e.g. IR01"
        },
        "name": {
          "type": "string",
          "description": "e.g. Interrail Global Pass"
        },
        "traveller": {
          "type": "string",
          "description": "Holder — should match a value in trip.travellers; omit for a pass shared by the whole group"
        },
        "ref": {
          "type": "string",
          "description": "Pass/booking reference"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "TransportStop": {
      "type": "object",
      "required": [
        "place",
        "time"
      ],
      "properties": {
        "place": {
          "type": "string",
          "description": "Station, stop, port or airport name — or a street address for taxi/door-to-door legs"
        },
        "time": {
          "type": "string",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$",
          "description": "HH:MM (24 h)"
        },
        "lat": {
          "type": "number",
          "minimum": -90,
          "maximum": 90,
          "description": "WGS-84 latitude — enables map rendering without a lookup table. For rail stations, coordinates can be looked up from https://github.com/trainline-eu/stations (stations.csv, 'latitude'/'longitude' columns, match on 'name' or 'uic_name'). For bus stops and other stops, query the Overpass API (https://overpass-api.de/api/interpreter) using tags highway=bus_stop or public_transport=platform — use the /find-stop project skill to do this."
        },
        "lng": {
          "type": "number",
          "minimum": -180,
          "maximum": 180,
          "description": "WGS-84 longitude — see lat description for source guidance."
        }
      },
      "additionalProperties": false
    },
    "Seat": {
      "type": "object",
      "required": [
        "traveller",
        "coach",
        "seat"
      ],
      "properties": {
        "traveller": {
          "type": "string"
        },
        "coach": {
          "type": [
            "integer",
            "string"
          ],
          "description": "Coach number or letter (some operators use lettered coaches)"
        },
        "deck": {
          "type": "string",
          "enum": [
            "upper",
            "lower"
          ]
        },
        "seat": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "CheckTime": {
      "type": "object",
      "required": [
        "date"
      ],
      "properties": {
        "date": {
          "type": "string",
          "format": "date"
        },
        "from": {
          "type": "string",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        },
        "by": {
          "type": "string",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        }
      },
      "additionalProperties": false
    },
    "Rating": {
      "type": "object",
      "description": "A rating from an external source",
      "required": [
        "score",
        "out_of",
        "source"
      ],
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0
        },
        "out_of": {
          "type": "number",
          "minimum": 0
        },
        "review_count": {
          "type": "integer",
          "minimum": 0
        },
        "source": {
          "type": "string",
          "description": "e.g. AllTrails, Google, Resident Advisor"
        }
      },
      "additionalProperties": false
    },
    "Proposal": {
      "type": "object",
      "description": "Collaboration metadata — tracks the lifecycle of a segment from first suggestion through to confirmation. If absent on a segment, the segment is implicitly confirmed.",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "suggested",
            "considering",
            "confirmed",
            "rejected"
          ],
          "description": "draft = added privately, not yet shared; suggested = proposed to the group; considering = under active discussion; confirmed = everyone agreed; rejected = decided against"
        },
        "proposed_by": {
          "type": "string",
          "description": "Name of the traveller who proposed this segment — should match a value in trip.travellers"
        },
        "note": {
          "type": "string",
          "description": "Reason for the suggestion, discussion thread, or rejection rationale"
        },
        "proposed_at": {
          "type": "string",
          "format": "date",
          "description": "ISO date the segment was first proposed"
        }
      },
      "additionalProperties": false
    },
    "EventSegment": {
      "type": "object",
      "required": [
        "id",
        "type",
        "subtype",
        "name",
        "date",
        "cost"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique segment identifier, e.g. seg-1"
        },
        "type": {
          "const": "event"
        },
        "proposal": {
          "$ref": "#/definitions/Proposal",
          "description": "Collaboration status — omit for already-confirmed/booked segments"
        },
        "notes": {
          "type": "string",
          "description": "Freeform notes visible on any segment type"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Alert banners rendered separately from notes — use for deadlines, safety info, and action items. Replaces the *** convention in freeform notes."
        },
        "subtype": {
          "type": "string",
          "enum": [
            "festival",
            "gig",
            "walk",
            "tour",
            "activity",
            "meal",
            "other"
          ],
          "description": "Distinguishes the kind of event for UI rendering and filtering"
        },
        "name": {
          "type": "string"
        },
        "artist": {
          "type": "string",
          "description": "Performer name — used for gigs; omit for walks/activities"
        },
        "venue": {
          "type": "string",
          "description": "Venue or trailhead name"
        },
        "address": {
          "type": "string"
        },
        "lat": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "lng": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "time": {
          "type": "string",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$",
          "description": "Start time HH:MM (24 h)"
        },
        "duration_min": {
          "type": "integer",
          "minimum": 1,
          "description": "Expected duration in minutes — useful for walks and timed gigs"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Event page, AllTrails link, etc."
        },
        "tickets_url": {
          "type": "string",
          "format": "uri"
        },
        "rating": {
          "$ref": "#/definitions/Rating"
        },
        "walk": {
          "type": "object",
          "description": "Walk-specific detail — only populated when subtype is 'walk'",
          "properties": {
            "distance_km": {
              "type": "number",
              "minimum": 0
            },
            "elevation_m": {
              "type": "integer",
              "description": "Total elevation gain in metres"
            },
            "difficulty": {
              "type": "string",
              "enum": [
                "easy",
                "moderate",
                "hard",
                "expert"
              ]
            },
            "route_type": {
              "type": "string",
              "enum": [
                "loop",
                "out-and-back",
                "point-to-point"
              ]
                },
                "surface": {
                  "type": "string",
                  "description": "e.g. rocky trail, forest path, coastal path"
                }
              },
              "additionalProperties": false
            },
            "parent_event_id": {
              "type": "string",
              "description": "ID of a parent EventSegment — e.g. a gig nested under a festival segment"
            },
            "pricing": {
              "type": "object",
              "description": "Named pricing tiers — keys are tier names, values describe the price",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "amount": {
                    "type": "number"
                  },
                  "from": {
                    "type": "number"
                  },
                  "to": {
                    "type": "number"
                  },
                  "currency": {
                    "type": "string",
                    "pattern": "^[A-Z]{3}$"
                  },
                  "note": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            },
            "cost": {
              "$ref": "#/definitions/Cost"
            }
          },
          "additionalProperties": false
    },
    "TransportSegment": {
      "type": "object",
      "required": [
        "id",
        "type",
        "mode",
        "operator",
        "date",
        "departs",
        "arrives",
        "duration_min",
        "cost"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique segment identifier, e.g. seg-1"
        },
        "type": {
          "const": "transport"
        },
        "proposal": {
          "$ref": "#/definitions/Proposal",
          "description": "Collaboration status — omit for already-confirmed/booked segments"
        },
        "notes": {
          "type": "string",
          "description": "Freeform notes visible on any segment type"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Alert banners rendered separately from notes — use for deadlines, safety info, and action items. Replaces the *** convention in freeform notes."
        },
        "mode": {
          "type": "string",
          "enum": [
            "train",
            "bus",
            "ferry",
            "flight",
            "taxi"
          ]
        },
        "operator": {
          "type": "string"
        },
        "service": {
          "type": "string",
          "description": "Train/flight number"
        },
        "ref": {
          "type": "string",
          "description": "Booking reference — omit when there is none (unbooked/walk-up legs); never use placeholders like \"n/a\""
        },
        "pass_id": {
          "type": "string",
          "description": "id of the trip-level pass (trip.passes) covering this leg"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "departs": {
          "$ref": "#/definitions/TransportStop"
        },
        "arrives": {
          "$ref": "#/definitions/TransportStop"
        },
        "duration_min": {
          "type": "integer",
          "minimum": 1
        },
        "class": {
          "type": "string",
          "description": "Travel class — omit where it doesn't apply (taxis, buses)"
        },
        "seats": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Seat"
          },
          "minItems": 1
        },
        "cost": {
          "$ref": "#/definitions/Cost"
        }
      },
      "additionalProperties": false
    },
    "AccommodationSegment": {
      "type": "object",
      "required": [
        "id",
        "type",
        "name",
        "host",
        "ref",
        "address",
        "lat",
        "lng",
        "checkin",
        "checkout",
        "guests",
        "nights",
        "self_checkin",
        "cost"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique segment identifier, e.g. seg-1"
        },
        "type": {
          "const": "accommodation"
        },
        "proposal": {
          "$ref": "#/definitions/Proposal",
          "description": "Collaboration status — omit for already-confirmed/booked segments"
        },
        "notes": {
          "type": "string",
          "description": "Freeform notes visible on any segment type"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Alert banners rendered separately from notes — use for deadlines, safety info, and action items. Replaces the *** convention in freeform notes."
        },
        "name": {
          "type": "string"
        },
        "host": {
          "type": "string"
        },
        "ref": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "lat": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "lng": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "phone": {
          "type": "string",
          "description": "Host phone in E.164 format"
        },
        "checkin": {
          "$ref": "#/definitions/CheckTime"
        },
        "checkout": {
          "$ref": "#/definitions/CheckTime"
        },
        "guests": {
          "type": "integer",
          "minimum": 1
        },
        "nights": {
          "type": "integer",
          "minimum": 1
        },
        "self_checkin": {
          "type": "boolean"
        },
        "cost": {
          "$ref": "#/definitions/Cost"
        }
      },
      "additionalProperties": false
    }
  }
}